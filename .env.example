# ToolCairn MCP — Environment Variables
# Copy to .env and fill in values for local development

# ── Deployment Mode ──────────────────────────────────────────────────────────
# dev: requires local Docker stack (see docker-compose.yml in toolcairn-engine)
# production: uses the hosted ToolCairn API (default for published package)
TOOLPILOT_MODE=production

# ── ToolCairn API ────────────────────────────────────────────────────────────
# URL of the hosted ToolCairn API (default points to production)
TOOLPILOT_API_URL=https://api.neurynae.com

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
